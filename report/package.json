{
  "name": "web-resilience-test-report-builder",
  "private": true,
  "version": "0.0.1",
  "description": "Build markdown reports under /report",
  "scripts": {
    "init-worktree": "node tools/init-report-worktree.js",
    "build": "node tools/build-report-root.js",
    "build:slide": "marp slide/index.md --html --allow-local-files --no-stdin -o slide/index.html",
    "publish": "node tools/publish-report.js"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.4.0",
    "marked": "^17.0.5"
  }
}
